# Copy this file to .env for local development, or set these as environment
# variables in CI for production builds.

# Canonical site URL. Used for sitemap generation, llms.txt, and canonical
# link tags.
SITE_URL=https://www.example.edu

# Base path for subdirectory deployments. Include the leading slash and
# trailing group/project segments that GitLab Pages serves from.
BASE_PATH=/my-group/my-site
