{
  "name": "astro-theme-university",
  "version": "0.5.3",
  "description": "Astro 7 + Svelte 5 theme package for university-style sites — layouts, components, content-collection helpers, post-build checks, and a Reveal.js deck theme. Re-brandable via CSS custom properties and data-only branding props.",
  "keywords": [
    "astro-component",
    "astro-integration",
    "theme",
    "university",
    "withastro"
  ],
  "homepage": "https://github.com/ANUcybernetics/astro-theme-university",
  "bugs": {
    "url": "https://github.com/ANUcybernetics/astro-theme-university/issues"
  },
  "license": "MIT",
  "author": "Ben Swift <ben@benswift.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ANUcybernetics/astro-theme-university.git"
  },
  "files": [
    "CHANGELOG.md",
    "index.ts",
    "types.ts",
    "types-shim.d.ts",
    "virtual.d.ts",
    "link-checker.ts",
    "a11y-checker.ts",
    "deck-checker.ts",
    "llms-txt.ts",
    "url.ts",
    "rehype-base-links.ts",
    "remark-callout.ts",
    "markdown.ts",
    "remark-default-layout.ts",
    "match-card-items.ts",
    "components/",
    "layouts/",
    "pages/",
    "schemas/",
    "shiki/",
    "styles/",
    "!**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./types": "./types.ts",
    "./markdown": "./markdown.ts",
    "./components/*": "./components/*",
    "./layouts/*": "./layouts/*",
    "./pages/*": "./pages/*",
    "./styles/*": "./styles/*",
    "./schemas": "./schemas/index.ts",
    "./url": "./url.ts",
    "./llms-txt": "./llms-txt.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.typecheck.json && pnpm --filter docs typecheck",
    "test": "vitest run",
    "test:examples": "vitest run --config vitest.examples.config.ts",
    "dev": "pnpm --filter docs dev",
    "build": "pnpm --filter docs build",
    "preview": "pnpm --filter docs preview",
    "extract-props": "node --experimental-strip-types scripts/extract-props.ts",
    "icons": "node scripts/list-icons.mjs",
    "lint": "oxlint --ignore-path .gitignore --ignore-pattern '*.astro' --ignore-pattern '*.svelte' && pnpm lint:css",
    "lint:css": "stylelint '**/*.css' --ignore-path .gitignore",
    "lint:css:fix": "stylelint '**/*.css' --fix --ignore-path .gitignore",
    "lint:fix": "oxlint --fix --ignore-path .gitignore && pnpm lint:css:fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@astro-community/astro-embed-youtube": "^0.5.10",
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/markdown-satteri": "^0.3.1",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/svelte": "^9.0.0",
    "@types/jsdom": "^28.0.3",
    "astro-broken-links-checker": "^1.1.0",
    "astro-icon": "^1.1.5",
    "axe-core": "^4.11.4",
    "jsdom": "^29.1.1",
    "linkedom": "^0.18.12",
    "p5": "^2.3.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-custom-heading-id": "^2.0.0",
    "remark-directive": "^4.0.0",
    "remark-smartypants": "^3.0.2",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@iconify-json/iconoir": "^1.2.11",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.3",
    "mdast-util-directive": "^3.1.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3",
    "unified": "^11.0.5",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@iconify-json/iconoir": "^1.2.0",
    "astro": "^7.0.0",
    "astromotion": ">=0.1.0",
    "lightningcss": "^1.32.0",
    "pagefind": "^1.0.0",
    "svelte": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "astromotion": {
      "optional": true
    },
    "pagefind": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24"
  }
}
