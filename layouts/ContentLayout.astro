---
import BaseLayout, { type BaseLayoutProps } from "./BaseLayout.astro";
import Hero from "../components/Hero.astro";

export interface ContentLayoutProps extends BaseLayoutProps {
  /** Lead text displayed below the title. */
  description?: string | null;
  /** Use a wider content column. */
  wide?: boolean;
}

type Props = ContentLayoutProps;

const { title, description, heroImage, heroImageAlt, ...baseProps } = Astro.props;
const transitionName = `card-title-${Astro.url.pathname.replace(/^\/|\/$/g, "").replace(/\//g, "-")}`;
---

<BaseLayout title={title} {...baseProps}>
  <slot name="head" slot="head" />
  {
    heroImage && (
      <Hero slot="hero" title={title} image={heroImage} imageAlt={heroImageAlt ?? ""} transitionName={transitionName} />
    )
  }
  {!heroImage && <h1 transition:name={transitionName}>{title}</h1>}
  {description && <p class="lead">{description}</p>}
  <slot />
</BaseLayout>
