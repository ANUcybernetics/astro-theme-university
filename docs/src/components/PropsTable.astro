---
import propsData from "../data/props.json";

interface Props {
  component: string;
  type?: string;
}

const { component, type } = Astro.props;

const componentData = propsData[component as keyof typeof propsData] as {
  props: { name: string; type: string; required: boolean; default?: string; description?: string }[];
  supportingTypes?: Record<string, { name: string; type: string; required: boolean; default?: string; description?: string }[]>;
};
if (!componentData) {
  throw new Error(`No props data found for component "${component}". Run the extract-props script.`);
}

const props = type
  ? componentData.supportingTypes?.[type] ?? []
  : componentData.props;
---

<table class="props-table">
  <thead>
    <tr>
      <th>Prop</th>
      <th>Type</th>
      <th>Default</th>
      <th>Description</th>
    </tr>
  </thead>
  <tbody>
    {
      props.map((prop) => (
        <tr>
          <td>
            <code>{prop.name}</code>
            {prop.required && <strong>*</strong>}
          </td>
          <td>
            <code>{prop.type}</code>
          </td>
          <td>{prop.default ? <code>{prop.default}</code> : "---"}</td>
          <td>{prop.description ?? ""}</td>
        </tr>
      ))
    }
  </tbody>
</table>
