{
  "name": "theme-dark",
  "displayName": "Theme Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#1a1a1a",
    "editor.foreground": "#e6e0d6"
  },
  "semanticTokenColors": {
    "class": "#2da5cc",
    "interface": "#3aafc2",
    "namespace": "#e08850",
    "property": "#c9a040",
    "type": "#3aafc2"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": {
        "foreground": "#8a805ddd"
      }
    },
    {
      "scope": [
        "delimiter.bracket",
        "delimiter",
        "invalid.illegal.character-not-allowed-here.html",
        "keyword.operator.rest",
        "keyword.operator.spread",
        "keyword.operator.type.annotation",
        "keyword.operator.relational",
        "keyword.operator.assignment",
        "keyword.operator.type",
        "meta.brace",
        "meta.tag.block.any.html",
        "meta.tag.inline.any.html",
        "meta.tag.structure.input.void.html",
        "meta.type.annotation",
        "meta.embedded.block.github-actions-expression",
        "storage.type.function.arrow",
        "meta.objectliteral.ts",
        "punctuation",
        "punctuation.definition.string.begin.html.vue",
        "punctuation.definition.string.end.html.vue"
      ],
      "settings": {
        "foreground": "#666666"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.language",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#d48a55"
      }
    },
    {
      "scope": ["entity", "entity.name"],
      "settings": {
        "foreground": "#2da5cc"
      }
    },
    {
      "scope": "variable.parameter.function",
      "settings": {
        "foreground": "#e6e0d6"
      }
    },
    {
      "scope": ["entity.name.tag", "tag.html"],
      "settings": {
        "foreground": "#d4940f"
      }
    },
    {
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#2da5cc"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type.class.jsdoc",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#d4940f"
      }
    },
    {
      "scope": [
        "storage",
        "storage.type",
        "support.type.builtin",
        "constant.language.undefined",
        "constant.language.null",
        "constant.language.import-export-all.ts"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#b0a89a"
      }
    },
    {
      "scope": [
        "text.html.derivative",
        "storage.modifier.package",
        "storage.modifier.import",
        "storage.type.java"
      ],
      "settings": {
        "foreground": "#e6e0d6"
      }
    },
    {
      "scope": ["string", "string punctuation.section.embedded source", "attribute.value"],
      "settings": {
        "foreground": "#e08850"
      }
    },
    {
      "scope": ["punctuation.definition.string"],
      "settings": {
        "foreground": "#e0885077"
      }
    },
    {
      "scope": ["punctuation.support.type.property-name"],
      "settings": {
        "foreground": "#c9a04077"
      }
    },
    {
      "scope": "support",
      "settings": {
        "foreground": "#c9a040"
      }
    },
    {
      "scope": [
        "property",
        "meta.property-name",
        "meta.object-literal.key",
        "entity.name.tag.yaml",
        "attribute.name"
      ],
      "settings": {
        "foreground": "#c9a040"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "invalid.deprecated.entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#c9a040"
      }
    },
    {
      "scope": ["variable", "identifier"],
      "settings": {
        "foreground": "#a0a0a0"
      }
    },
    {
      "scope": ["support.type.primitive", "entity.name.type"],
      "settings": {
        "foreground": "#3aafc2"
      }
    },
    {
      "scope": "namespace",
      "settings": {
        "foreground": "#e08850"
      }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment.compound", "meta.var.expr.ts"],
      "settings": {
        "foreground": "#a0a0a0"
      }
    },
    {
      "scope": "invalid.broken",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": "invalid.deprecated",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": "invalid.illegal",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": "invalid.unimplemented",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": "carriage-return",
      "settings": {
        "background": "#f97583",
        "content": "^M",
        "fontStyle": "italic underline",
        "foreground": "#24292e"
      }
    },
    {
      "scope": "message.error",
      "settings": {
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": "string variable",
      "settings": {
        "foreground": "#e08850"
      }
    },
    {
      "scope": ["source.regexp", "string.regexp"],
      "settings": {
        "foreground": "#c4704f"
      }
    },
    {
      "scope": [
        "string.regexp.character-class",
        "string.regexp constant.character.escape",
        "string.regexp source.ruby.embedded",
        "string.regexp string.regexp.arbitrary-repitition"
      ],
      "settings": {
        "foreground": "#e08850"
      }
    },
    {
      "scope": "string.regexp constant.character.escape",
      "settings": {
        "foreground": "#d4940f"
      }
    },
    {
      "scope": ["support.constant"],
      "settings": {
        "foreground": "#d48a55"
      }
    },
    {
      "scope": ["keyword.operator.quantifier.regexp", "constant.numeric", "number"],
      "settings": {
        "foreground": "#2da5cc"
      }
    },
    {
      "scope": ["keyword.other.unit"],
      "settings": {
        "foreground": "#b0a89a"
      }
    },
    {
      "scope": ["constant.language.boolean", "constant.language"],
      "settings": {
        "foreground": "#d4940f"
      }
    },
    {
      "scope": "meta.module-reference",
      "settings": {
        "foreground": "#d4940f"
      }
    },
    {
      "scope": "punctuation.definition.list.begin.markdown",
      "settings": {
        "foreground": "#d48a55"
      }
    },
    {
      "scope": ["markup.heading", "markup.heading entity.name"],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#d4940f"
      }
    },
    {
      "scope": "markup.quote",
      "settings": {
        "foreground": "#3aafc2"
      }
    },
    {
      "scope": "markup.italic",
      "settings": {
        "fontStyle": "italic",
        "foreground": "#e6e0d6"
      }
    },
    {
      "scope": "markup.bold",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#e6e0d6"
      }
    },
    {
      "scope": "markup.raw",
      "settings": {
        "foreground": "#d4940f"
      }
    },
    {
      "scope": ["markup.deleted", "meta.diff.header.from-file", "punctuation.definition.deleted"],
      "settings": {
        "background": "#86181d",
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": ["markup.inserted", "meta.diff.header.to-file", "punctuation.definition.inserted"],
      "settings": {
        "background": "#144620",
        "foreground": "#85e89d"
      }
    },
    {
      "scope": ["markup.changed", "punctuation.definition.changed"],
      "settings": {
        "background": "#c24e00",
        "foreground": "#ffab70"
      }
    },
    {
      "scope": ["markup.ignored", "markup.untracked"],
      "settings": {
        "background": "#79b8ff",
        "foreground": "#2f363d"
      }
    },
    {
      "scope": "meta.diff.range",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#b392f0"
      }
    },
    {
      "scope": "meta.diff.header",
      "settings": {
        "foreground": "#79b8ff"
      }
    },
    {
      "scope": "meta.separator",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#79b8ff"
      }
    },
    {
      "scope": "meta.output",
      "settings": {
        "foreground": "#79b8ff"
      }
    },
    {
      "scope": [
        "brackethighlighter.tag",
        "brackethighlighter.curly",
        "brackethighlighter.round",
        "brackethighlighter.square",
        "brackethighlighter.angle",
        "brackethighlighter.quote"
      ],
      "settings": {
        "foreground": "#d1d5da"
      }
    },
    {
      "scope": "brackethighlighter.unmatched",
      "settings": {
        "foreground": "#fdaeb7"
      }
    },
    {
      "scope": [
        "constant.other.reference.link",
        "string.other.link",
        "punctuation.definition.string.begin.markdown",
        "punctuation.definition.string.end.markdown"
      ],
      "settings": {
        "foreground": "#e08850"
      }
    },
    {
      "scope": ["markup.underline.link.markdown", "markup.underline.link.image.markdown"],
      "settings": {
        "fontStyle": "underline",
        "foreground": "#e6e0d690"
      }
    },
    {
      "scope": ["type.identifier", "constant.other.character-class.regexp"],
      "settings": {
        "foreground": "#3aafc2"
      }
    },
    {
      "scope": ["entity.other.attribute-name.html.vue"],
      "settings": {
        "foreground": "#2da5cc"
      }
    },
    {
      "scope": ["invalid.illegal.unrecognized-tag.html"],
      "settings": {
        "fontStyle": "normal"
      }
    }
  ]
}
