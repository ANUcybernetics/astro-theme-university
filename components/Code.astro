---
import { Code as AstroCode } from "astro:components";
import type { ComponentProps } from "astro/types";
import themeLight from "../shiki/theme-light.json";
import themeDark from "../shiki/theme-dark.json";

type AstroCodeProps = ComponentProps<typeof AstroCode>;

export type CodeProps = Omit<AstroCodeProps, "theme" | "themes" | "defaultColor">;

type Props = CodeProps;

const props = Astro.props;
---

<AstroCode
  {...props}
  themes={{ light: themeLight, dark: themeDark }}
  defaultColor={false}
/>
